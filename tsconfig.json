{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@kickstart/harness": ["packages/harness/src/index.ts"],
      "@kickstart/harness/runtime/session": ["packages/harness/src/runtime/session.ts"],
      "@kickstart/harness/runtime/runner": ["packages/harness/src/runtime/runner.ts"],
      "@kickstart/harness/runtime/sse": ["packages/harness/src/runtime/sse.ts"],
      "@kickstart/harness/*": ["packages/harness/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
