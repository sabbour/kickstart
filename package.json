{
  "name": "kickstart",
  "private": true,
  "version": "0.1.0",
  "description": "AI-guided onboarding for deploying apps to AKS",
  "workspaces": [
    "packages/*",
    "packages/web/api"
  ],
  "scripts": {
    "build": "npm run clean --workspaces --if-present && npm run build --workspaces --if-present",
    "test": "npx vitest run",
    "lint": "eslint packages/*/src/**/*.ts",
    "api:build": "npm run build -w @kickstart/core && npm run build -w @kickstart/api",
    "clean": "npm run clean --workspaces --if-present",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "serve": "^14.2.6",
    "typescript": "^6.0.2"
  }
}
