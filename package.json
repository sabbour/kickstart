{
  "name": "kickstart",
  "private": true,
  "version": "0.7.0",
  "description": "AI-guided onboarding for deploying apps to AKS",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "packages/web/api"
  ],
  "squad": {
    "worktrees": true
  },
  "scripts": {
    "build": "npm run clean --workspaces --if-present && npm run build --workspaces --if-present",
    "test": "npx vitest run",
    "lint": "eslint packages/*/src/**/*.ts packages/*/src/**/*.tsx",
    "api:build": "npm run build -w @kickstart/core && npm run build -w @kickstart/api",
    "clean": "npm run clean --workspaces --if-present",
    "dev": "npm run build -w @kickstart/core && concurrently \"npm run dev:vite\" \"npx swa start\"",
    "dev:vite": "cd packages/web && npx vite --port 5173",
    "dev:web": "npx serve packages/web -l 4280 --no-clipboard",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "cookie": "0.7.2",
    "tmp": "0.2.5",
    "hono": "4.12.14",
    "follow-redirects": "1.16.0"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "monaco-editor": "0.55.1",
    "serve": "^14.2.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
