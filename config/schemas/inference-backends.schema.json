{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aks-kickstart/config/inference-backends.schema.json",
  "title": "Inference Backends Configuration",
  "description": "Defines inference backend options for the agentic_app track.",
  "type": "object",
  "required": [
    "version",
    "appliesTo",
    "selectionEvent",
    "uiSurface",
    "backends"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "appliesTo": {
      "type": "string",
      "description": "Track id this backend selection applies to."
    },
    "selectionEvent": {
      "type": "string",
      "description": "A2UI event name fired when the user picks a backend."
    },
    "uiSurface": {
      "type": "object",
      "required": [
        "surfaceId",
        "component",
        "defaultValue"
      ],
      "properties": {
        "surfaceId": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "defaultValue": {
          "type": "string"
        },
        "defaultValueRule": {
          "type": "string"
        }
      }
    },
    "backends": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/backend"
      }
    }
  },
  "definitions": {
    "backend": {
      "type": "object",
      "required": [
        "id",
        "label",
        "description",
        "recommended",
        "deploymentShape",
        "requiresGpuNodes",
        "handoffPath",
        "questionPolicy",
        "provenance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "recommended": {
          "type": "boolean"
        },
        "deploymentShape": {
          "type": "string",
          "enum": [
            "managed_endpoint",
            "in_cluster_workload",
            "external_endpoint"
          ]
        },
        "requiresGpuNodes": {
          "type": "boolean"
        },
        "handoffPath": {
          "type": "string"
        },
        "groundingTool": {
          "type": "object",
          "required": [
            "tool",
            "callBeforePresentingChoices"
          ],
          "properties": {
            "tool": {
              "type": "string"
            },
            "callBeforePresentingChoices": {
              "type": "boolean"
            },
            "queryPattern": {
              "type": "string"
            },
            "useResultField": {
              "type": "string"
            },
            "rule": {
              "type": "string"
            }
          }
        },
        "questionPolicy": {
          "type": "object",
          "required": [
            "maxQuestions",
            "askOneAtATime"
          ],
          "properties": {
            "maxQuestions": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10
            },
            "askOneAtATime": {
              "type": "boolean"
            },
            "candidateQuestionsInPriorityOrder": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "key"
                ],
                "properties": {
                  "key": {
                    "type": "string"
                  },
                  "askOnlyIf": {
                    "type": "string"
                  },
                  "groundedBy": {
                    "type": "string"
                  },
                  "forbidden": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "fallbackIfNoMatch": {
              "type": "string"
            },
            "forbidden": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        },
        "provenance": {
          "type": "string",
          "enum": [
            "extracted",
            "derived",
            "proposed"
          ],
          "description": "Source provenance of this entry."
        }
      }
    }
  }
}
