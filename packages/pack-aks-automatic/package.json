  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "@kickstart/harness": "*",
    "@openai/agents": "^0.8.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@fluentui/react-components": "*",
    "@fluentui/react-icons": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "peerDependencies": {
    "@fluentui/react-components": "^9.0.0",
    "@fluentui/react-icons": "^2.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
