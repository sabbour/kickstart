{
  "name": "@kickstart/api",
  "version": "1.0.0",
  "private": true,
  "description": "Azure Functions API for Kickstart web surface — LLM proxy",
  "type": "module",
  "main": "dist/functions/*.js",
  "scripts": {
    "build": "node -e \"const f=require('fs');f.rmSync('dist',{recursive:true,force:true})\" && node esbuild.config.mjs",
    "build:tsc": "tsc",
    "start": "func start",
    "clean": "node -e \"const f=require('fs');f.rmSync('dist',{recursive:true,force:true});f.rmSync('tsconfig.tsbuildinfo',{force:true})\""
  },
  "dependencies": {
    "@azure/functions": "^4.6.0",
    "@kickstart/harness": "1.0.1",
    "bicep-node": "^0.0.9",
    "vite": "^8.0.9"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0"
  }
}
