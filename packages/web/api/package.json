{
  "name": "@kickstart/api",
  "version": "1.0.0",
  "private": true,
  "description": "Azure Functions API for Kickstart web surface — LLM proxy",
  "type": "module",
  "main": "dist/functions/*.js",
  "scripts": {
    "build": "npm run build -w @kickstart/harness && node -e \"const f=require('fs');f.rmSync('dist',{recursive:true,force:true})\" && node esbuild.config.mjs",
    "build:tsc": "tsc",
    "start": "func start",
    "clean": "node -e \"const f=require('fs');f.rmSync('dist',{recursive:true,force:true});f.rmSync('tsconfig.tsbuildinfo',{force:true})\""
  },
  "dependencies": {
    "@azure/functions": "^4.6.0",
    "@kickstart/harness": "*",
    "@fluentui/react-icons": "^2.0.324",
    "@types/dompurify": "^3.2.0",
    "bicep-node": "^0.0.9",
    "dompurify": "^3.4.0",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
