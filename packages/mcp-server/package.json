{
  "name": "@sabbour/kickstart-mcp",
  "version": "1.0.2",
  "description": "MCP server for AKS Kickstart — exposes conversation tools and A2UI responses",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kickstart-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "clean": "node -e \"const f=require('fs');f.rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "vitest": "^4.1.4",
    "@aks-kickstart/harness": "*",
    "@aks-kickstart/pack-core": "*",
    "@aks-kickstart/pack-azure": "*",
    "@aks-kickstart/pack-aks-automatic": "*",
    "@aks-kickstart/pack-github": "*",
    "esbuild": "^0.28.0"
  },
  "keywords": [
    "mcp",
    "kickstart",
    "aks",
    "a2ui"
  ],
  "files": [
    "dist/**",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
