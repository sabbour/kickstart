# Kickstart Environment Variables
# Copy this file to packages/web/api/local.settings.json and fill in your values
# Do NOT commit local.settings.json to source control — it's in .gitignore

# ============================================================================
# Azure OpenAI (Required)
# ============================================================================

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY

# Preferred deployment names (v2 standard)
KICKSTART_CHAT_MODEL=gpt-5.4
KICKSTART_CODEX_MODEL=gpt-5.4
KICKSTART_INSPIRE_MODEL=gpt-5.4-nano

# Legacy fallbacks (deprecated, but still supported)
# If KICKSTART_* vars are not set, these are used with a deprecation warning
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4
# AZURE_OPENAI_CODEX_DEPLOYMENT=gpt-5.4

# ============================================================================
# Packs & Features
# ============================================================================

# Comma-separated list of packs to enable (default: all)
# Valid values: core,azure,github,aks-automatic
# KICKSTART_PACKS=core,azure,github,aks-automatic

# Enable playground scenarios for component development and testing
KICKSTART_PLAYGROUND=false

# Enable debug logging for troubleshooting agent behavior
KICKSTART_DEBUG_ALLOWED=false

# ============================================================================
# Azure Authentication
# ============================================================================

# Azure Entra ID (formerly Azure AD) service principal credentials
AZURE_CLIENT_ID=your-app-id
AZURE_CLIENT_SECRET=your-secret
AZURE_TENANT_ID=your-tenant-id

# ============================================================================
# GitHub OAuth (Optional)
# ============================================================================

# GitHub OAuth application credentials (from GitHub Developer Settings)
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# Optional: customize OAuth scopes (default: repo,user:email)
# GITHUB_OAUTH_SCOPES=repo,user:email

# ============================================================================
# Security Keys
# ============================================================================

# Session encryption key for GitHub OAuth cookies
# If not set, falls back to GITHUB_CLIENT_SECRET or AZURE_CLIENT_SECRET
# GITHUB_SESSION_SECRET=your-session-secret

# Secret for authorizing deployment run initiations
# If not set, falls back to GITHUB_SESSION_SECRET or AZURE_CLIENT_SECRET
# DEPLOY_RUN_SECRET=your-run-secret

# ============================================================================
# Runtime
# ============================================================================

NODE_ENV=development
PORT=4280
FUNCTIONS_WORKER_RUNTIME=node
AzureWebJobsStorage=
